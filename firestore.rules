rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId}/leads/{leadId} {
      function isValidLead(data) {
        return data.keys().hasOnly([
          'projectNumber',
          'customerName',
          'followUpDate',
          'completed',
          'createdAt',
          'updatedAt'
        ])
          && data.projectNumber is string
          && data.projectNumber.size() > 0
          && data.customerName is string
          && data.customerName.size() > 0
          && data.followUpDate is string
          && data.followUpDate.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
          && data.completed is bool
          && data.createdAt is timestamp
          && data.updatedAt is timestamp;
      }

      allow read, delete: if request.auth != null
        && request.auth.uid == userId;

      allow create: if request.auth != null
        && request.auth.uid == userId
        && isValidLead(request.resource.data)
        && request.resource.data.completed == false;

      allow update: if request.auth != null
        && request.auth.uid == userId
        && isValidLead(request.resource.data)
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.completed == resource.data.completed;
    }
  }
}
